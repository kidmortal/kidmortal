</Button>\r\n        </Paper>\r\n      </Grid>\r\n      <Grid item xs={12} sm={3}>\r\n        <Paper\r\n          className={card === 2 ? classes.classCard : \"\"}\r\n          variant=\"outlined\"\r\n        >\r\n          <ClassName>Thief</ClassName>\r\n          <Button\r\n            className={classes.button}\r\n            onClick={() => {\r\n              setClass(2);\r\n            }}\r\n            style={{ backgroundColor: \"transparent\" }}\r\n          >\r\n            <ClassImage src={Icons[\"Thief\"]} />\r\n          </Button>\r\n        </Paper>\r\n      </Grid>\r\n      <Grid item xs={12} sm={3}>\r\n        <Paper\r\n          className={card === 3 ? classes.classCard : \"\"}\r\n          variant=\"outlined\"\r\n        >\r\n          <ClassName>Archer</ClassName>\r\n          <Button\r\n            className={classes.button}\r\n            onClick={() => {\r\n              setClass(3);\r\n            }}\r\n            style={{ backgroundColor: \"transparent\" }}\r\n          >\r\n            <ClassImage src={Icons[\"Archer\"]} />\r\n          </Button>\r\n        </Paper>\r\n      </Grid>\r\n    </>\r\n  );\r\n};\r\n\r\nexport default ClassCard;\r\n","C:\\code\\kidmortal\\src\\components\\inserirChequeCliente.js",["309","310"],"C:\\code\\kidmortal\\src\\components\\editSelectedCheque.js",[],"C:\\code\\kidmortal\\src\\components\\changePermissionsMenu.js",["311","312","313","314"],"C:\\code\\kidmortal\\src\\pages\\pagamentos.js",["315"],"C:\\code\\kidmortal\\src\\store\\modules\\rootReducer.js",[],"C:\\code\\kidmortal\\src\\components\\listaPedidos.js",["316"],"C:\\code\\kidmortal\\src\\assets\\skills\\index.js",[],"C:\\code\\kidmortal\\src\\components\\clientesInput.js",["317","318","319"],"C:\\code\\kidmortal\\src\\components\\monsterBattle.js",["320","321","322","323","324","325"],"C:\\code\\kidmortal\\src\\components\\selectedChequeLoteMenu.js",["326","327","328"],"C:\\code\\kidmortal\\src\\components\\editProdutoNf.js",["329","330","331"],{"rule